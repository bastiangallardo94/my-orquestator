{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "anthropic/claude-haiku-4-5",
  "formatter": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 15000
  },
  "mcp": {
    "codebase-memory-mcp": {
      "enabled": true,
      "type": "local",
      "command": ["/PATH/TO/codebase-memory-mcp"]
    },
    "backend-api-qa": {
      "enabled": true
    }
  },
  "plugin": [
    "./.opencode/plugins/ponytail.mjs"
  ],
  "agent": {
    "orquestador-deep": {
      "description": "Subagente profundo para análisis, planificación y codificación TDD",
      "mode": "subagent",
      "model": "opencode/gpt-5.1-codex",
      "temperature": 0.1,
      "hidden": true,
      "color": "#6366f1",
      "steps": 30,
      "prompt": "{file:~/.config/opencode/agents/orquestador-deep.md}",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "*": "ask",
          "npm *": "allow",
          "git status *": "allow",
          "grep *": "allow"
        },
        "task": { "*": "deny" },
        "skill": "allow",
        "webfetch": "allow",
        "question": "allow",
        "todowrite": "allow"
      }
    },
    "orquestador-fast": {
      "description": "Subagente rápido para QA, dependencias, docs y reportes",
      "mode": "subagent",
      "model": "opencode/gpt-5.1-codex",
      "temperature": 0.3,
      "hidden": true,
      "color": "#10b981",
      "steps": 20,
      "prompt": "{file:~/.config/opencode/agents/orquestador-fast.md}",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": {
          "*": "ask",
          "npm *": "allow",
          "git status *": "allow",
          "grep *": "allow"
        },
        "task": { "*": "deny" },
        "question": "allow",
        "todowrite": "allow",
        "webfetch": "allow"
      }
    }
  }
}
