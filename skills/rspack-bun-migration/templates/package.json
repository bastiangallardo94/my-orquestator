{
  "name": "my-microfrontend",
  "version": "1.0.0",
  "description": "Microfrontend with Rspack + Bun",
  "scripts": {
    "start": "cross-env NODE_ENV=development rspack serve --mode development",
    "build": "cross-env NODE_ENV=production rspack --mode production",
    "build:dev": "cross-env NODE_ENV=development rspack --mode development",
    "serve": "cross-env NODE_ENV=production rspack serve",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageDirectory=coverage",
    "lint": "eslint --ext .ts,.tsx src/",
    "lint:fix": "eslint --ext .ts,.tsx src/ --fix",
    "type-check": "tsc --noEmit",
    "pre-commit": "bun run type-check && bun run lint && bun run test",
    "clean": "rm -rf dist node_modules",
    "install:yarn": "bun install --yarn",
    "analyze": "cross-env NODE_ENV=production rspack --mode production --analyze"
  },
  "dependencies": {
    "process": "^0.11.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.0",
    "single-spa": "^6.0.0",
    "single-spa-react": "^6.0.1",
    "@mui/material": "^7.3.11",
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@reduxjs/toolkit": "^2.2.1",
    "react-redux": "^9.1.0"
  },
  "devDependencies": {
    "@module-federation/enhanced": "^2.5.0",
    "@rspack/cli": "^2.0.4",
    "@rspack/core": "^2.0.4",
    "@rspack/dev-server": "^2.0.1",
    "@rspack/plugin-react-refresh": "^2.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "typescript": "^5.4.5",
    "cross-env": "^7.0.3",
    "dotenv": "^17.4.2",
    "jest": "^29.7.0",
    "@testing-library/react": "^15.0.2",
    "@testing-library/jest-dom": "^6.4.2",
    "sass-embedded": "^1.99.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "css-loader": "^7.1.2",
    "postcss": "^8.4.38",
    "postcss-loader": "^8.1.1",
    "tailwindcss": "^3.4.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.2.0"
  }
}
