# Environment Configuration Example
# Copy this file to .env.development or .env.production and fill in the values

# ==========================================
# APP Configuration
# ==========================================
APP_NAME=myApp
APP_PORT=3000
APP_URL=http://localhost:3000/
APP_PATH=/app

# ==========================================
# API Configuration
# ==========================================
BFF_URL=https://api.example.com
LOGIN_URL=https://example.com/login

# ==========================================
# Module Federation - Remote Apps
# ==========================================
# Format: appName@url/remoteEntry.js
AUTHENTICATION_APP=auth@http://localhost:3001/remoteEntry.js

# ==========================================
# Development Settings
# ==========================================
APP_DEV=true
CONFIGURATION_STORE_NAME=mystore
IS_PRODUCTION=false
AUTH_CONFIG_CLIENT=portal
STORE_DEBUG=true

# ==========================================
# UI Settings
# ==========================================
SIDEBAR_ENABLED=false
COMPACT_MENU_LABEL=My Application
